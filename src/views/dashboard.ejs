<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
    />
    <title>ScheduleBot Dashboard</title>
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="app" id="top">
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
          <span class="brand-mark">S</span>
          <span class="brand-name">ScheduleBot</span>
        </div>

        <div class="sidebar-body">
          <p class="nav-group-label">Menu</p>
          <nav class="sidebar-nav">
            <a class="nav-item active" href="#status">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M12 7v5l3 3"></path>
              </svg>
              <span>Status</span>
            </a>
            <a class="nav-item" href="#create-schedule">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 5v14M5 12h14"></path>
              </svg>
              <span>Create</span>
            </a>
            <a class="nav-item" href="#schedule-list">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                <path d="M3 10h18M8 2v4M16 2v4"></path>
              </svg>
              <span>Schedules</span>
            </a>
          </nav>
        </div>

        <div class="sidebar-footer">
          <span class="status-indicator <%= waState.ready ? 'is-on' : 'is-off' %>"></span>
          <span class="sidebar-footer-text">WhatsApp <%= waState.ready ? 'connected' : 'offline' %></span>
        </div>
      </aside>

      <main class="main">
        <header class="top-nav">
          <div class="top-nav-inner">
            <button class="icon-btn" id="sidebarMenuBtn" type="button" aria-label="Open menu">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                <path d="M9.5 4v16"></path>
              </svg>
            </button>
            <div class="top-nav-title-wrap">
              <p class="top-nav-title">Dashboard</p>
              <p class="top-nav-subtitle">WhatsApp Schedule Control</p>
            </div>
          </div>
        </header>

        <div class="container">
          <section class="stats-grid">
            <div class="stat-card">
              <p class="stat-label">Total</p>
              <p class="stat-value"><%= scheduleStats.total %></p>
            </div>
            <div class="stat-card">
              <p class="stat-label">Pending</p>
              <p class="stat-value"><%= scheduleStats.pending %></p>
            </div>
            <div class="stat-card">
              <p class="stat-label">Sent</p>
              <p class="stat-value"><%= scheduleStats.sent %></p>
            </div>
            <div class="stat-card">
              <p class="stat-label">Failed</p>
              <p class="stat-value"><%= scheduleStats.failed %></p>
            </div>
          </section>

          <section class="grid two-cols">
            <article class="card" id="status">
              <div class="card-header">
                <h2 class="card-title">WhatsApp Status</h2>
                <p class="card-description">Connection state and QR pairing</p>
              </div>
              <div class="card-content">
                <div class="status-row">
                  <span class="badge <%= waState.ready ? 'badge-success' : 'badge-warning' %>" id="wa-status">
                    <%= waState.status %>
                  </span>
                </div>

                <div id="wa-qr-wrap" class="qr-wrap" <%= waState.qrCodeDataUrl ? '' : 'hidden' %>>
                  <% if (waState.qrCodeDataUrl) { %>
                  <img src="<%= waState.qrCodeDataUrl %>" alt="QR WhatsApp" class="qr" />
                  <% } else { %>
                  <img src="" alt="QR WhatsApp" class="qr" />
                  <% } %>
                  <p id="wa-qr-caption" class="qr-caption">Scan this QR code from WhatsApp to connect the bot.</p>
                </div>
                <p id="wa-qr-empty" class="muted" <%= waState.qrCodeDataUrl ? 'hidden' : '' %>>
                  QR will appear automatically when re-login is needed.
                </p>

                <ul class="tips muted">
                  <li>Personal: use a number like 62812xxxx</li>
                  <li>Group: use the group ID, with or without @g.us</li>
                </ul>
              </div>
            </article>

            <article class="card" id="create-schedule">
              <div class="card-header">
                <h2 class="card-title">Create Schedule</h2>
                <p class="card-description">Queue a new WhatsApp message</p>
              </div>
              <div class="card-content">
                <form id="schedule-form">
                  <div class="field">
                    <label for="targetType">Target Type</label>
                    <select id="targetType" name="targetType" required>
                      <option value="personal" selected>Personal Chat</option>
                      <option value="group">Group Chat</option>
                    </select>
                  </div>

                  <div class="field">
                    <label for="targetValue" id="targetValueLabel">Destination Number (62812xxxx)</label>
                    <input id="targetValue" name="targetValue" required />
                    <p class="hint" id="targetHint">Personal example: 6281234567890</p>
                  </div>

                  <div class="group-tools" id="groupTools" hidden>
                    <div class="group-tools-head">
                      <label for="groupPicker">Select Group From WhatsApp Account</label>
                      <button type="button" class="btn btn-outline btn-sm" id="refreshGroupsBtn">Refresh Groups</button>
                    </div>
                    <select id="groupPicker">
                      <option value="">Loading group list...</option>
                    </select>
                    <p class="hint" id="groupFetchHint">Pick a group to auto-fill the ID.</p>
                  </div>

                  <div class="field">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" rows="4" required></textarea>
                  </div>

                  <div class="field">
                    <label for="scheduleAt">Send Time</label>
                    <input id="scheduleAt" name="scheduleAt" type="datetime-local" required />
                  </div>

                  <button type="submit" class="btn btn-primary btn-block">Save Schedule</button>
                </form>
                <p id="form-feedback" class="feedback"></p>
              </div>
            </article>
          </section>

          <section class="card table-card" id="schedule-list">
            <div class="card-header section-head">
              <div>
                <h2 class="card-title">Schedule List</h2>
                <p class="card-description">Track every pending, sent, and failed job in one clean table.</p>
              </div>
            </div>
            <div class="card-content no-pad">
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>ID</th>
                      <th>Type</th>
                      <th>Target</th>
                      <th>Message</th>
                      <th>Time</th>
                      <th>Status</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!schedules.length) { %>
                    <tr>
                      <td colspan="7" class="muted">No schedules yet</td>
                    </tr>
                    <% } %>

                    <% schedules.forEach((item) => { %>
                    <tr>
                      <td><%= item.id %></td>
                      <td>
                        <span class="badge badge-outline">
                          <%= item.targetType === 'group' ? 'group' : 'personal' %>
                        </span>
                      </td>
                      <td><%= item.targetValue %></td>
                      <td class="cell-message"><%= item.message %></td>
                      <td class="js-local-datetime" data-iso="<%= item.scheduleAt %>">
                        <%= dayjs(item.scheduleAt).format('DD MMM YYYY HH:mm:ss') %>
                      </td>
                      <td>
                        <span class="badge badge-<%= item.status %>"><%= item.status %></span>
                      </td>
                      <td class="cell-action">
                        <button class="btn btn-ghost btn-sm btn-delete" data-id="<%= item.id %>">Delete</button>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </section>
        </div>
      </main>
    </div>

    <script src="/public/app.js"></script>
  </body>
</html>
