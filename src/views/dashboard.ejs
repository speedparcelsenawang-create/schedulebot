<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
    />
    <title>ScheduleBot Dashboard</title>
    <link rel="stylesheet" href="/public/styles.css" />
    <script>
      (function () {
        try {
          var storedTheme = window.localStorage.getItem('schedulebot-theme');
          document.documentElement.setAttribute('data-theme', storedTheme === 'light' ? 'light' : 'dark');
        } catch (error) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();

      (function () {
        if (window.location.hash) {
          document.documentElement.classList.add('has-route-hash');
        }
      })();
    </script>
  </head>
  <body>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="app" id="top">
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
          <span class="brand-mark">S</span>
          <span class="brand-name">ScheduleBot</span>
        </div>

        <div class="sidebar-body">
          <p class="nav-group-label">Menu</p>
          <nav class="sidebar-nav">
            <a class="nav-item active" href="#account">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="8" r="4"></circle>
                <path d="M4 21c0-4 3.5-6 8-6s8 2 8 6"></path>
              </svg>
              <span>Account</span>
            </a>
            <a class="nav-item" href="#schedule">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                <path d="M3 10h18M8 2v4M16 2v4"></path>
              </svg>
              <span>Schedule</span>
            </a>
            <a class="nav-item" href="#custom-commands">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 17l6-6-6-6"></path>
                <path d="M12 19h8"></path>
              </svg>
              <span>Custom Command</span>
            </a>
          </nav>
        </div>

        <div class="sidebar-footer">
          <span class="status-indicator <%= waState.ready ? 'is-on' : 'is-off' %>"></span>
          <span class="sidebar-footer-text">WhatsApp <%= waState.ready ? 'connected' : 'offline' %></span>
        </div>
      </aside>

      <main class="main">
        <header class="top-nav">
          <div class="top-nav-inner">
            <button class="icon-btn" id="sidebarMenuBtn" type="button" aria-label="Open menu">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                <path d="M9.5 4v16"></path>
              </svg>
            </button>
            <div class="top-nav-title-wrap">
              <nav class="top-nav-breadcrumb" aria-label="Breadcrumb">
                <span class="crumb" id="breadcrumbRoot">Dashboard</span>
                <span class="crumb-sep">/</span>
                <span class="crumb" id="breadcrumbPage">Account</span>
                <span class="crumb-sep" id="breadcrumbSectionSep" hidden>/</span>
                <span class="crumb is-current" id="breadcrumbSection" hidden></span>
              </nav>
            </div>
            <button class="icon-btn theme-toggle-btn" id="themeToggleBtn" type="button" aria-label="Toggle light/dark mode">
              <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="4"></circle>
                <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
              </svg>
              <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
              </svg>
            </button>
          </div>
        </header>

        <div class="container">
          <section class="page" data-page="account" id="account">
            <div class="grid two-cols">
              <article class="card">
                <div class="card-header">
                  <h2 class="card-title">Account</h2>
                  <p class="card-description">Connection state, QR pairing, and pairing code login</p>
                </div>
                <div class="card-content">
                  <div class="status-row">
                    <span class="badge <%= waState.ready ? 'badge-success' : 'badge-warning' %>" id="wa-status">
                      <%= waState.status %>
                    </span>
                  </div>

                  <div class="method-tabs">
                    <button type="button" class="method-tab active" id="methodTabQr" data-method="qr">QR Code</button>
                    <button type="button" class="method-tab" id="methodTabPhone" data-method="phone" <%= waState.ready ? 'disabled' : '' %>>Phone Number</button>
                  </div>

                  <div id="qr-method" class="method-panel">
                    <div id="wa-connected-wrap" class="connected-wrap" <%= waState.ready ? '' : 'hidden' %>>
                      <span class="connected-icon" aria-hidden="true">✓</span>
                      <p class="connected-title">WhatsApp connected</p>
                      <p class="connected-subtitle">Session is active. QR code is not needed right now.</p>
                    </div>

                    <div id="wa-qr-wrap" class="qr-wrap" <%= !waState.ready && waState.qrCodeDataUrl ? '' : 'hidden' %>>
                      <% if (waState.qrCodeDataUrl) { %>
                      <img src="<%= waState.qrCodeDataUrl %>" alt="QR WhatsApp" class="qr" />
                      <% } else { %>
                      <img src="" alt="QR WhatsApp" class="qr" />
                      <% } %>
                      <p id="wa-qr-caption" class="qr-caption">Scan this QR code from WhatsApp to connect the bot.</p>
                    </div>
                    <p id="wa-qr-empty" class="muted" <%= !waState.ready && !waState.qrCodeDataUrl ? '' : 'hidden' %>>
                      QR will appear automatically when re-login is needed.
                    </p>
                  </div>

                  <div id="phone-method" class="method-panel" hidden>
                    <div class="field">
                      <label for="pairingPhone">Phone Number</label>
                      <input id="pairingPhone" placeholder="60812xxxxxxx" <%= waState.ready ? 'disabled' : '' %> />
                      <p class="hint">Enter your WhatsApp number with country code, no + or spaces.</p>
                    </div>
                    <button type="button" class="btn btn-primary btn-block" id="requestPairingBtn" <%= waState.ready ? 'disabled' : '' %>>Get Pairing Code</button>
                    <p id="pairing-feedback" class="feedback"></p>

                    <div id="pairing-code-wrap" class="pairing-code-wrap" hidden>
                      <p class="muted">Your pairing code:</p>
                      <p class="pairing-code" id="pairing-code-value"></p>
                      <p class="hint">Open WhatsApp on your phone &rarr; Linked Devices &rarr; Link with phone number, then enter this code.</p>
                    </div>
                  </div>

                  <ul class="tips muted" id="account-target-tips" hidden>
                    <li>Group: use the group ID, with or without @g.us</li>
                  </ul>
                </div>
              </article>
            </div>
          </section>

          <section class="page" data-page="schedule" id="schedule" hidden>
            <div class="stats-grid">
              <div class="stat-card">
                <p class="stat-label">Total</p>
                <p class="stat-value"><%= scheduleStats.total %></p>
              </div>
              <div class="stat-card">
                <p class="stat-label">Pending</p>
                <p class="stat-value"><%= scheduleStats.pending %></p>
              </div>
              <div class="stat-card">
                <p class="stat-label">Sent</p>
                <p class="stat-value"><%= scheduleStats.sent %></p>
              </div>
              <div class="stat-card">
                <p class="stat-label">Failed</p>
                <p class="stat-value"><%= scheduleStats.failed %></p>
              </div>
            </div>

            <div class="method-tabs" id="schedule-tabs" role="tablist" aria-label="Schedule tabs">
              <button type="button" class="method-tab active" id="scheduleTabCreate" data-tab="create" role="tab" aria-controls="schedule-create-panel" aria-selected="true">Create Schedule</button>
              <button type="button" class="method-tab" id="scheduleTabList" data-tab="list" role="tab" aria-controls="schedule-list-panel" aria-selected="false">Schedule List</button>
            </div>

            <div class="method-panel" id="schedule-create-panel" role="tabpanel" aria-labelledby="scheduleTabCreate">
              <article class="card" id="create-schedule">
                <div class="card-header">
                  <h2 class="card-title">Create Schedule</h2>
                  <p class="card-description">Queue a new WhatsApp message</p>
                </div>
                <div class="card-content">
                  <form id="schedule-form">
                    <div class="field">
                      <label for="targetType">Target Type</label>
                      <select id="targetType" name="targetType" required>
                        <option value="personal" selected>Personal Chat</option>
                        <option value="group">Group Chat</option>
                      </select>
                    </div>

                    <div class="field">
                      <label for="targetValue" id="targetValueLabel">Destination Number (62812xxxx)</label>
                      <input id="targetValue" name="targetValue" required />
                      <p class="hint" id="targetHint">Personal example: 6281234567890</p>
                    </div>

                    <div class="group-tools" id="groupTools" hidden>
                      <div class="group-tools-head">
                        <label for="groupPicker">Select Group From WhatsApp Account</label>
                        <button type="button" class="btn btn-outline btn-sm" id="refreshGroupsBtn">Refresh Groups</button>
                      </div>
                      <select id="groupPicker">
                        <option value="">Loading group list...</option>
                      </select>
                      <p class="hint" id="groupFetchHint">Pick a group to auto-fill the ID.</p>
                    </div>

                    <div class="field">
                      <label for="message">Message</label>
                      <textarea id="message" name="message" rows="4" required></textarea>
                    </div>

                    <div class="field field-narrow">
                      <label for="scheduleAt">Send Time</label>
                      <input id="scheduleAt" name="scheduleAt" type="datetime-local" required />
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">Save Schedule</button>
                  </form>
                  <p id="form-feedback" class="feedback"></p>
                </div>
              </article>
            </div>

            <div class="method-panel" id="schedule-list-panel" role="tabpanel" aria-labelledby="scheduleTabList" hidden>
              <article class="card table-card" id="schedule-list">
                <div class="card-header section-head">
                  <div>
                    <h2 class="card-title">Schedule List</h2>
                    <p class="card-description">Track every pending, sent, and failed job in one clean table.</p>
                  </div>
                </div>
                <div class="card-content no-pad">
                  <div class="table-wrap">
                    <table>
                      <thead>
                        <tr>
                          <th>ID</th>
                          <th>Type</th>
                          <th>Target</th>
                          <th>Message</th>
                          <th>Time</th>
                          <th>Status</th>
                          <th></th>
                        </tr>
                      </thead>
                      <tbody>
                        <% if (!schedules.length) { %>
                        <tr>
                          <td colspan="7" class="muted">No schedules yet</td>
                        </tr>
                        <% } %>

                        <% schedules.forEach((item) => { %>
                        <tr>
                          <td><%= item.id %></td>
                          <td>
                            <span class="badge badge-outline">
                              <%= item.targetType === 'group' ? 'group' : 'personal' %>
                            </span>
                          </td>
                          <td><%= item.targetValue %></td>
                          <td class="cell-message"><%= item.message %></td>
                          <td class="js-local-datetime" data-iso="<%= item.scheduleAt %>">
                            <%= dayjs(item.scheduleAt).format('DD MMM YYYY HH:mm:ss') %>
                          </td>
                          <td>
                            <span class="badge badge-<%= item.status %>"><%= item.status %></span>
                          </td>
                          <td class="cell-action">
                            <button class="btn btn-ghost btn-sm btn-delete" data-id="<%= item.id %>">Delete</button>
                          </td>
                        </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </article>
            </div>
          </section>

          <section class="page" data-page="custom-commands" id="custom-commands" hidden>
            <div class="method-tabs" id="command-tabs" role="tablist" aria-label="Custom command tabs">
              <button type="button" class="method-tab active" id="commandTabCreate" data-tab="create" role="tab" aria-controls="command-create-panel" aria-selected="true">Add Command</button>
              <button type="button" class="method-tab" id="commandTabList" data-tab="list" role="tab" aria-controls="command-list-panel" aria-selected="false">Command List</button>
            </div>

            <div class="method-panel" id="command-create-panel" role="tabpanel" aria-labelledby="commandTabCreate">
              <article class="card">
                <div class="card-header">
                  <h2 class="card-title">Add Custom Command</h2>
                  <p class="card-description">Auto-reply to incoming WhatsApp messages by trigger</p>
                </div>
                <div class="card-content">
                  <form id="command-form">
                    <input type="hidden" id="commandOriginalTrigger" value="" />
                    <div class="field">
                      <label for="commandTrigger">Trigger</label>
                      <input id="commandTrigger" name="trigger" placeholder="!hello" required />
                      <p class="hint">Must start with !, example: !hello</p>
                    </div>

                    <div class="field">
                      <label for="commandMediaType">Media Type</label>
                      <select id="commandMediaType" name="mediaType" required>
                        <option value="">Select media type first</option>
                        <option value="none">No media</option>
                        <% mediaTypes.forEach((type) => { %>
                        <option value="<%= type %>"><%= type %></option>
                        <% }) %>
                      </select>
                      <p class="hint">Select media type to show related fields.</p>
                    </div>

                    <div id="command-advanced-fields" hidden>
                      <div class="field" id="commandResponseField">
                        <label for="commandResponse">Response Text</label>
                        <textarea id="commandResponse" name="response" rows="3" placeholder="Reply message..."></textarea>
                      </div>

                      <div class="field" id="commandMediaSourceField">
                        <label for="commandMediaSource">Media Source</label>
                        <select id="commandMediaSource" name="mediaSource">
                          <option value="url" selected>By URL</option>
                          <option value="upload">Upload File</option>
                        </select>
                      </div>

                      <div class="field" id="commandMediaUrlField">
                        <label for="commandMediaUrl">Media URL <span class="muted">(optional)</span></label>
                        <input id="commandMediaUrl" name="mediaUrl" placeholder="https://..." />
                      </div>

                      <div class="field" id="commandMediaUploadField" hidden>
                        <label for="commandMediaUpload">Upload Media File <span class="muted">(max 20MB)</span></label>
                        <input id="commandMediaUpload" name="mediaUpload" type="file" />
                        <p class="hint" id="commandMediaUploadHint">Choose a file to upload and use as media source.</p>
                      </div>

                      <div class="field" id="commandFileNameField" hidden>
                        <label for="commandFileName">File Name <span class="muted">(document only, optional)</span></label>
                        <input id="commandFileName" name="fileName" placeholder="brochure.pdf" />
                      </div>

                      <div class="field" id="commandButtonsField">
                        <div class="field-head">
                          <label>Buttons <span class="muted">(optional)</span></label>
                          <button type="button" class="btn btn-outline btn-sm" id="addButtonRowBtn">Add Button</button>
                        </div>
                        <div id="buttonRows" class="button-rows"></div>
                        <p class="hint">Supports quick reply, open link, call, and copy code buttons.</p>
                      </div>

                      <div class="field-row optional-meta-row" id="commandOptionalMetaRow">
                        <div class="field">
                          <label for="commandCategory">Category <span class="muted">(optional)</span></label>
                          <select id="commandCategory" name="category">
                            <% commandCategories.forEach((cat) => { %>
                            <option value="<%= cat %>"><%= cat %></option>
                            <% }) %>
                          </select>
                        </div>
                        <div class="field">
                          <label for="commandDescription">Description <span class="muted">(optional)</span></label>
                          <input id="commandDescription" name="description" placeholder="Short note about this command" />
                        </div>
                      </div>
                    </div>

                    <div class="form-actions">
                      <button type="submit" class="btn btn-block btn-save-command" id="commandSubmitBtn" disabled>Save Command</button>
                      <button type="button" class="btn btn-outline btn-block" id="commandCancelBtn" hidden>Cancel Edit</button>
                    </div>
                  </form>
                  <p id="command-feedback" class="feedback"></p>
                </div>
              </article>
            </div>

            <div class="method-panel" id="command-list-panel" role="tabpanel" aria-labelledby="commandTabList" hidden>
              <article class="card table-card">
                <div class="card-header section-head">
                  <div>
                    <h2 class="card-title">Command List</h2>
                    <p class="card-description">All active auto-reply triggers</p>
                  </div>
                </div>
                <div class="card-content no-pad">
                  <div class="table-wrap">
                    <table>
                      <thead>
                        <tr>
                          <th>Trigger</th>
                          <th>Category</th>
                          <th>Response</th>
                          <th>Media</th>
                          <th></th>
                        </tr>
                      </thead>
                      <tbody id="command-table-body">
                        <% if (!customCommands.length) { %>
                        <tr>
                          <td colspan="5" class="muted">No custom commands yet</td>
                        </tr>
                        <% } %>

                        <% customCommands.forEach((item) => { %>
                        <tr data-trigger="<%= item.trigger %>">
                          <td><code><%= item.trigger %></code></td>
                          <td><span class="badge badge-outline"><%= item.category %></span></td>
                          <td class="cell-message"><%= item.response %></td>
                          <td>
                            <% if (item.mediaType) { %>
                            <span class="badge badge-outline"><%= item.mediaType %></span>
                            <% } else { %>
                            <span class="muted">-</span>
                            <% } %>
                          </td>
                          <td class="cell-action">
                            <button class="btn btn-ghost btn-sm btn-edit-command" data-trigger="<%= item.trigger %>">Edit</button>
                            <button class="btn btn-ghost btn-sm btn-delete-command" data-trigger="<%= item.trigger %>">Delete</button>
                          </td>
                        </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </article>
            </div>
          </section>
        </div>
      </main>
    </div>

    <script>
      window.__CUSTOM_COMMANDS__ = <%- JSON.stringify(customCommands) %>;
    </script>
    <script src="/public/app.js"></script>
  </body>
</html>
